{{define "form"}}
  <div class="form_container{{if .AutosubmitOnDataChange}} form_container-autosubmit{{end}}{{if .AutosubmitFirstTime}} form_container-autosubmitfirsttime{{end}}"
    data-form-name="{{.HeaderName}}"
    data-form-icon="{{.HeaderIcon}}"
  >

    <div class="box">
      {{range $scriptPath := .ScriptPaths}}
        <script src="{{$scriptPath}}"></script>
      {{end}}

      <form method="POST" action="{{.Action}}" class="form prago_form" enctype="multipart/form-data" data-item-version="{{.ItemVersion}}" novalidate>
        {{if .CSRFToken}}
          <input type="hidden" name="_csrfToken" value="{{.CSRFToken}}">
        {{end}}
        <input type="hidden" name="_itemversion" value="{{.ItemVersion}}">

        <div class="form_errors hidden"></div>

        <div class="form_conflict hidden"></div>
        
        {{range $item := .Items}}
          <div class="form_label{{if .TextOver}} form_label-textover{{end}}{{if .Hidden}} form_label-hidden{{end}}{{if .Required}} form_label-required{{end}}"
            data-id="{{.ID}}"
          >
            <a class="form_label_textover">
              {{.TextOver}}
            </a>
            <div class="form_label_content">
            {{if eq .HiddenName false}}
              {{range $description := .DescriptionsBefore}}
                <div class="form_label_description">{{$description}}</div>
              {{end}}
              <label for="{{.UUID}}" class="form_label_text">
                {{if .Icon}}
                  <img src="/admin/api/icons?file={{$item.Icon}}&color={{PragoBlackColor}}" class="form_label_text_icon">
                {{end}}
                {{.Name}}
                {{if .Required}}
                  <span class="form_label_required">Povinné</span>
                {{end}}
                {{if .HelpURL}}
                  <a href="{{.HelpURL}}" class="form_label_text_help"><img src="/admin/api/icons?file=glyphicons-basic-196-circle-empty-info.svg&color={{PragoBlackColor}}" data-tooltip="Nápověda"></a>
                {{end}}
              </label>
              {{if .Description}}
                <div class="form_label_description">{{.Description}}</div>
              {{end}}
              {{range $description := .DescriptionsAfter}}
                <div class="form_label_description">{{$description}}</div>
              {{end}}
            {{end}}
            <div class="form_label_errors hidden"></div>
            <div class="form_label_contents">
              {{.GetContent}}
              {{if .SuggestionURL}}
                <div class="form_suggestions" data-suggestions-url="{{.SuggestionURL}}"></div>
              {{end}}
            </div>
            </div>
          </div>
        {{end}}

        <progress class="progress form_progress hidden"></progress>

      </form>
    </div>

    <div class="form_task hidden">
      <div class="form_task_header">
        <div class="form_task_header_top">
          <div class="form_task_status" data-tooltip=""></div>
          <div class="form_task_progress_text"></div>
        </div>
        <progress class="form_task_progress" value="" max="1"></progress>
        <div class="form_task_header_bottom">
          <div class="form_task_interval"></div>
          <button class="btn form_task_stop" data-tooltip="Ukončit úlohu">
            <img src="/admin/api/icons?file=glyphicons-basic-176-stop.svg&color={{PragoBlackColor}}" class="btn_icon">
            Ukončit
          </button>
        </div>
      </div>

      <div class="form_table form_task_table">
        <table>
          <tbody></tbody>
        </table>
      </div>
    </div>
    <div class="form_after_content">{{.HTMLAfter}}</div>
  </div>

{{end}}