{{define "accordions"}} 
    <div class="accordions">
        {{range $item := .}}
            <div class="accordion">
                <div class="accordion_header" onclick="this.closest('.accordion').classList.toggle('accordion-visible')">
                    {{if $item.Icon}}<img src="/admin/api/icons?file={{$item.Icon}}&color={{PragoBlackColor}}" class="accordion_header_icon">{{end}}
                    <div class="accordion_header_name">{{$item.Name}}</div>
                    <img src="/admin/api/icons?file=glyphicons-basic-221-chevron-down.svg&color={{PragoBlackColor}}" class="accordion_header_chevron">
                </div>
                <div class="accordion_content">{{$item.Text}}</div>
            </div>
        {{end}}
    </div>
{{end}}