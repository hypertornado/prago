{{define "board"}}
  <div class="board">
  
  <h1 class="board_name">{{if PragoIconExists .BoardIcon}}<img src="/admin/api/icons?file={{.BoardIcon}}&color={{PragoBlackColor}}" class="board_icon">{{end}}<div class="board_name_text">{{.BoardName}}</div></h1>

  {{if .MainDashboard}}
    {{template "dashboard" .MainDashboard}}
  {{end}}

  {{if .Resources}}
    {{$boardURL := .BoardURL}}
    <div class="board_resources">
      {{range $i, $resource := .Resources}}
        {{if ne $resource.URL $boardURL}}
        <a href="{{$resource.URL}}" class="board_resource" title="{{$resource.Name}}">
          {{if $resource.Icon}}
            <div class="board_resource_left"><img class="board_resource_icon" src="/admin/api/icons?file={{$resource.Icon}}&color={{PragoBaseColor}}"></div>
          {{end}}
          <div class="board_resource_name">{{$resource.Name}}</div>
          <div class="board_resource_subname"></div>
        </a>
        {{end}}
      {{end}}
    </div>
  {{end}}

  {{range $dashboard := .Dashboards}}
    {{template "dashboard" $dashboard}}
  {{end}}

  <div>
{{end}}