{{define "views"}}
  {{range $item := .}}
    {{template "view" $item}}
  {{end}}
{{end}}

{{define "view"}}
  <div class="box">
  {{if .Name}}
  <div class="view_header">
    {{if .Name}}
      <span class="view_header_name">
        {{if .Icon}}
          <img src="/admin/api/icons?file={{.Icon}}&color={{PragoBlackColor}}" class="view_header_icon">
        {{end}}
        {{.Name}}
        {{if .Subname}}
          <span class="view_header_subname">
            {{- .Subname -}}
          </span>
        {{end}}
      </span>
    {{end}}
    <div class="view_header_tabs">
      {{range $navItem := .Buttons}}
        <a href="{{$navItem.URL}}" class="btn" title="{{$navItem.Name}}"><img src="/admin/api/icons?file={{.Icon}}&color={{PragoBlackColor}}" class="btn_icon"></a>
      {{end}}
    </div>
  </div>
  {{end}}
  {{- if .Header}}
    {{- template "box_header" .Header}}
  {{end}}
  {{if .Relation}}
    {{template "view_relationlist" .Relation}}
  {{end}}

  {{template "item_views" .Items}}

  {{range $result := .SearchResults}}
    <a href="{{$result.URL}}" class="search">
      <div class="search_icon"></div>
      <div class="search_right">
        <div class="search_name">{{$result.Name}}</div>
      </div>
    </a>
  {{end}}


  {{if .Pagination}}
    <div class="search_pagination">
      {{range $page := .Pagination}}
        <a href="{{$page.URL}}" class="search_pagination_page{{if $page.Selected}} search_pagination_page-selected{{end}}">{{$page.Title}}</a>
      {{end}}
    </div>
  {{end}}

  </div>


{{end}}


{{define "item_views"}}
  <div class="views">
  {{range $item := .}}
    <div class="view">
    {{if $item.Name}}
      <div class="view_name">
        {{if $item.Icon}}
          <img src="/admin/api/icons?file={{$item.Icon}}&color={{PragoBlackColor}}" class="view_name_icon">
        {{end}}
        {{$item.Name}}
        {{if $item.EditURL}}
          <a href="{{$item.EditURL}}" class="view_edit">
            <img src="/admin/api/icons?file=glyphicons-basic-31-pencil.svg&color={{PragoBaseColor}}" class="view_edit_icon">{{$item.EditName}}
          </a>
        {{end}}
      </div>
    {{end}}
    <div class="view_content">
      {{- $item.Content -}}
    </div>
    </div>
  {{end}}
  </div>
{{end}}

{{define "view_text"}}
  {{- if . -}}
    {{- . -}}
  {{- end -}}
{{end}}

{{define "view_textarea"}}
  {{- if . -}}
    <span>{{- . -}}</span>
  {{- end -}}
{{end}}

{{define "view_markdown"}}
  {{- if . -}}
    {{- PragoMarkdown . -}}
  {{- end -}}
{{end}}

{{define "view_cdn_file"}}
  <div class="fileview">
  {{if .OriginalURL}}
      <a href="{{.OriginalURL}}" class="fileview_preview" style="background-image: url('{{.GiantURL}}');"></a>
  {{end}}
  </div>
{{end}}

{{define "view_image"}}
  {{if .}}
  <div class="imageview" data-images="{{.}}">
    <progress class="progress" value="" max=""></progress>
  </div>
  {{end}}
{{end}}

{{define "view_video"}}
  {{if .}}
  <div class="videoview" data-videos="{{.}}">
    <video class="videoview_video hidden"></video>
    <progress class="progress" value="" max=""></progress>
  </div>
  {{end}}
{{end}}

{{define "view_place"}}
  {{if .}}
  <div class="admin_item_view_place" data-value="{{.}}">
    <progress class="progress" value="" max=""></progress>
  </div>
  {{end}}
{{end}}

{{define "view_relation"}}
    {{if .}}
      <div class="admin_item_view_relation">
      {{range $item := .}}
      <a class="preview" href="{{$item.URL}}">
        {{if $item.Image}}
          <img src="{{PragoCSS $item.Image}}" class="preview_image" loading="lazy">
        {{end}}
        <div class="preview_right">
          <div class="preview_name">{{$item.Name}}</div>
          <div class="preview_description" title="{{$item.Description}}">{{$item.Description}}</div>
        </div>
      </a>
      {{end}}
      </div>
    {{else -}}
    {{- end}}
{{end}}

{{define "view_relationlist"}}
  <div class="admin_relationlist"
    data-source-resource="{{.SourceResource}}"
    data-target-resource="{{.TargetResource}}"
    data-target-field="{{.TargetField}}"
    data-id-value="{{.IDValue}}"
    data-count="{{.Count}}"
  >
    <div class="admin_relationlist_target">
    </div>
    <div class="admin_relationlist_loading hidden">
      <progress class="progress list_progress"></progress>
    </div>
    <div class="admin_relationlist_more hidden">
      <div class="btn"><img src="/admin/api/icons?file=glyphicons-basic-221-chevron-down.svg&color={{PragoBlackColor}}" class="btn_icon"></div>
    </div>
  </div>
{{end}}

{{define "view_relationlist_response"}}
      {{template "view_relation" .}}
{{end}}