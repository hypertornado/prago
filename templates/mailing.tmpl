{{define "mailing"}}

<!doctype html>
<html>
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>{{.Name}}</title>
    <meta name="description" content="">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <style type="text/css">
      body {
        font-family: Roboto, -apple-system, BlinkMacSystemFont, "Helvetica Neue", "Segoe UI", Oxygen, Ubuntu, Cantarell, "Open Sans", sans-serif;
      }

      .mailing_box {
        padding: 5px;
        border: 0px solid red;
        max-width: 500px;
        margin: 0 auto;
      }

      input {
        max-width: 200px;
        display: block;
      }

    h1 {
        font-size: 2rem;
        line-height: 1em;
        text-align: center;
        font-weight: 500;
        margin: 10px 0px;
    }

    h2 {
        font-size: 1.2rem;
        line-height: 1.3em;
    }

    a {
        color: #{{PragoBaseColor}};
    }
    a:hover {
      text-decoration: none;
    }

    a.mailing_button {
        background-color: #{{PragoBaseColor}};
        color: white;
        text-decoration: white;
        padding: 5px 10px;
        border-radius: 10px;
        margin-top: 20px;
        margin-bottom: 20px;
        display: block;
        text-align: center;
        font-size: 20px;
        line-height: 30px;
        font-weight: 500;
        box-shadow: rgba(50, 50, 93, 0.25) 0px 2px 5px -1px, rgba(0, 0, 0, 0.3) 0px 1px 3px -1px;
    }

    .mailing_logo {
        height: 70px;
    }

    .mailing_logo_a {
        margin-top: 20px;
        display: block;
        text-align: center;
        margin-bottom: 20px;
    }

    .mailing_name {
      margin-bottom: 20px;
    }

    .mailing_image {
      border-radius: 10px;
      width: 100%;
    }

    .mailing_subname {
      text-align: center;
      font-weight: 500;
      font-size: 1.2rem;
      line-height: 1em;
    }

    .mailing_description {
        font-size: 1.2rem;
        line-height: 1.3em;
        text-align: center;

    }

    .mailing_footer {
      text-align: center;
      font-size: .8rem;
      line-height: 1.3em;
      margin: 30px 0px;
      padding: 10px 0px;
      clear: both;
    }

    .mailing_footer, .mailing_footer a {
      color: #999;
    }

    .mailing_content img {
      max-width: 100%;
    }

    .mailing_block {
      margin-top: 50px;
      clear: both;
    }

    .mailing_block img {
      float: left;
      aspect-ratio: 3 / 2;
      object-fit: cover;
      max-width: 120px;
      margin: 0px 10px 10px 0px;
      border-radius: 5px;
    }

    .mailing_block h3 {
      font-size: 1.1rem;
      line-height: 1.3em;
      margin: 0px;
    }

    .section_name {
      font-weight: bold;
      margin: 10px 0px 3px 0px;

    }


.form_table {
  margin-top: 5px;
}

.form_table table {
  border-collapse: collapse;
  border-spacing: 0;
  background-color: white;
  min-width: 100%;
  margin: 0px auto;
  border-left: 1px solid #eeeeee;
  border: 1px solid #eeeeee;
}

.form_table td {
  padding: 5px 10px;
  border: 1px solid #eeeeee;
  vertical-align: top;
}

.form_table tr:last-child {
  border-bottom: 1px solid #eeeeee;
}

.form_table_footer {
  padding: 5px 0px;
  color: $gray;
}

.form_table_cell-center {
  text-align: center;
}

.form_table_cell-right {
  text-align: right;
}

.form_table_cell-nowrap {
  white-space: nowrap;
}

.form_table_cell-green {
  background-color: palegreen;
}

.form_table_cell-orange {
  background-color: orange;
}

.form_table_cell-red {
  background-color: palevioletred;
}

.form_table_cell-header {
  font-weight: bold;
}

.form_table_cell-pre {
  font-family: monospace;
  white-space: nowrap;
}

.form_table_cell_descriptionbefore, .form_table_cell_descriptionafter {
  font-size: .8em;
  line-height: 1.3em;
  font-weight: normal;
  color: $black;
}

.form_table_cell a {
  text-decoration: none;
}

.form_table_cell a:hover .form_table_cell_text {
  text-decoration: underline;
}

.form_table_cell .btn {
  margin-top: 2.5px;
  margin-bottom: 2.5px;
}

.form_table_cell_textafter {
  color: $gray;
  font-size: .8em;
  line-height: 1.3em;
  font-weight: normal;
  font-style: italic;

  max-width: 100px;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}


    </style>

  </head>
  <body>

    {{$baseURL := .BaseURL}}
    {{$logoURL := .LogoURL}}
    <div class="mailing_box">

        <a href="{{$baseURL}}" class="mailing_logo_a"><img src="{{$logoURL}}" class="mailing_logo"></a>


        <div class="mailing_name">
        {{if .PreName}}
            <div class="mailing_subname">{{.PreName}}</div>
        {{end}}
        {{if .Name}}
            <h1>{{.Name}}</h1>
        {{end}}
        {{if .PostName}}
            <div class="mailing_subname">{{.PostName}}</div>
        {{end}}
        </div>

        <div class="mailing_content">

        {{if .Description}}
            <p class="mailing_description">{{.Description}}</p>
        {{end}}

        {{range $image := .Images}}
          <img src="{{$image.Thumb}}" class="mailing_image">
        {{end}}

        {{if .Text}}
            <p class="mailing_text">{{.Text}}</p>
        {{end}}

        {{range $section := .Sections}}
          <div class="section_name">{{$section.Name}}</div>
          <div class="section_text">{{$section.Text}}</div>
          {{if $section.Table}}
            {{$section.Table.ExecuteHTML}}
          {{end}}
        {{end}}

        {{if .Button}}
            <a href="{{.Button.URL}}" class="mailing_button">{{.Button.Name}}</a>
        {{end}}

        </div>

        {{if .FooterDescription}}
            <div class="mailing_footer">{{.FooterDescription}}</div>
        {{end}}

    </div>
  </body>
</html>

{{end}}

{{define "mailing_message"}}
  <h2>{{.Sender}}</h2>
  <i>{{.Message}}</i>
{{end}}