{{define "tabs"}}
  {{$tabs := .}}
  {{if gt (len $tabs) 0}}
    <div class="navigation_tabs">
      {{range $i, $item := .}}
        <a href="{{$item.SafeURL}}" class="navigation_tab{{if $item.Selected}} navigation_tab-selected{{end}}">
            {{if $item.Icon}}
              <img src="/admin/api/icons?file={{$item.Icon}}&color={{if $item.Selected}}ffffff{{else}}{{PragoBlackColor}}{{end}}" alt="{{$item.Name}}" class="navigation_tab_icon">
            {{end}}
            <div class="navigation_tab_name">{{$item.Name}}</div>
        </a>
      {{end}}
    </div>
  {{end}}
{{end}}