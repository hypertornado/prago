{{define "search_results"}}
    <div class="search_results">
    {{range $result := .}}
        <a href="{{$result.URL}}" class="search">
        <div class="search_icon"></div>
        <div class="search_right">
            <div class="search_name">{{$result.Name}}</div>
        </div>
        </a>
    {{end}}
    </div>
{{end}}