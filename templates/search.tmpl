{{define "search_suggest"}}
  <div class="search_suggestions_content">
    {{range $i, $item := .}}
      <a href="{{$item.URL}}" class="search_suggestion search_suggestion-noimage" data-position="{{$i}}">
        {{if $item.Icon}}
          <img class="search_suggestion_icon" src="/admin/api/icons?file={{$item.Icon}}&color={{PragoBaseColor}}">
        {{end}}
        <div class="search_suggestion_right">
          {{if $item.Prename}}
            <div class="search_suggestion_prename">{{$item.Prename}}</div>
          {{end}}
          <div class="search_suggestion_name">{{$item.Name}}</div>
        </div>
      </a>
    {{end}}
  </div>
{{end}}

{{define "search_results"}}
    <div class="search_results">
    {{range $result := .}}
        <a href="{{$result.URL}}" class="search">
        <div class="search_icon"></div>
        <div class="search_right">
            <div class="search_name">{{$result.Name}}</div>
        </div>
        </a>
    {{end}}
    </div>
{{end}}

{{define "searchbox"}}
  <form class="searchbox" action="/admin/_search">
    <input class="searchbox_input" type="search" placeholder="Vyhledávání" name="q" value="{{.}}"  autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false">
    <button class="searchbox_button">
      <img src="/admin/api/icons?file=glyphicons-basic-28-search.svg&color={{PragoBaseColor}}">
    </button>
    <div class="searchbox_suggestions"></div>
  </form>
{{end}}