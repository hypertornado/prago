{{define "box_header" -}}
    <div class="box_header">
        {{if .TextBefore}}
            <div class="box_textbefore">{{.TextBefore}}</div>
        {{end}}
        {{if .Name}}
            <div class="box_name">
                {{if .Icon}}
                    <div class="box_icon">
                        <img src="/admin/api/icons?file={{.Icon}}&color={{PragoStyleColor .Style}}">
                    </div>
                {{end}}
                {{.Name}}
            </div>
        {{end}}
        {{if .TextAfter}}
            <div class="box_textafter">{{.TextAfter}}</div>
        {{end}}
        {{if .Buttons}}
            <div class="box_header_buttons">
                {{range $button := .Buttons}}                    
                    <a href="{{$button.URL}}" class="btn{{if $button.Style}} btn-{{$button.Style}}{{end}}">
                        {{if $button.Icon}}<img src="/admin/api/icons?file={{$button.Icon}}&color={{PragoStyleColor $button.Style}}" class="btn_icon">{{end}}
                        <div class="btn_text">{{$button.Name}}</div>
                    </a>
                {{end}}
            </div>
        {{end}}
    </div>
{{end}}