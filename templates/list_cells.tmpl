{{define "list_cells"}}
  {{range $row := .Rows}}
    <div data-id="{{$row.ID}}" data-url="{{$row.URL}}" class="list_row" data-actions="{{$row.Actions.JSON}}" data-prename="{{$row.PreName}}" data-name="{{$row.Name}}" data-description="{{$row.Description}}" data-image-url="{{$row.ImageURL}}">
      {{if $row.ListContent.AllowsMultipleActions}}
        <div class="list_row_multiple" data-id="{{$row.ID}}">
          <div class="list_cell_multiple_pseudocheckbox"></div>
        </div>
      {{end}}
      {{range $cell := $row.Items}}
        <div class="list_cell{{if .Style}} list_cell-{{.Style}}{{end}}{{if .Alignment}} list_cell-{{.Alignment}}{{end}}" {{if $cell.Name}}title="{{$cell.Name}}"{{end}} data-cell-id="{{$cell.ItemID}}" {{if $cell.FetchURL}}data-fetch-url="{{$cell.FetchURL}}"{{end}}>
          {{template "list_cell" $cell}}
        </div>
      {{end}}
    </div>
  {{end}}
{{end}}

{{define "list_cell"}}
    <span class="list_cell_images">
      {{- range $image := .Images}}
        {{if $image -}}
          <img src="{{PragoCSS (PragoThumb $image)}}" class="list_cell_image" loading="lazy">
        {{- end -}}
      {{end -}}
    </span>
    <img class="list_cell_icon{{if not .Icon}} hidden{{end}}" src="{{if .Icon}}/admin/api/icons?file={{.Icon}}&color={{.IconColor}}{{end}}">
    <span class="list_cell_name">{{.Name}}</span>
{{end}}